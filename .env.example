# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
APP_URL="YOUR_APP_URL"

# SUPABASE_URL: The absolute API URL of your Supabase project (e.g., https://yourproject.supabase.co)
SUPABASE_URL="YOUR_SUPABASE_URL"

# SUPABASE_ANON_KEY: The public/anonymous key of your Supabase project
SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"

# SUPABASE_SERVICE_ROLE_KEY: Optional/Recommended. The service role key for full admin read/write bypass
SUPABASE_SERVICE_ROLE_KEY="YOUR_SUPABASE_SERVICE_ROLE_KEY"

# BREVO_API_KEY: Transactional email SMTP API key from your Brevo SMTP & API settings page
BREVO_API_KEY="YOUR_BREVO_API_KEY"

# BREVO_SENDER_EMAIL: The verified sender email address in your Brevo account (e.g., info@yourdomain.com)
BREVO_SENDER_EMAIL="no-reply@buzzna.com"

# BREVO_SENDER_NAME: The brand name appearing in customer inbox headers
BREVO_SENDER_NAME="BuzzNa D74 Cloud OS"

# PAYSTACK_PUBLIC_KEY: Public API key for Paystack
PAYSTACK_PUBLIC_KEY="pk_test_YOUR_PAYSTACK_PUBLIC_KEY"

# PAYSTACK_SECRET_KEY: Secret API key for Paystack transactions initialization and verification
PAYSTACK_SECRET_KEY="sk_test_YOUR_PAYSTACK_SECRET_KEY"

